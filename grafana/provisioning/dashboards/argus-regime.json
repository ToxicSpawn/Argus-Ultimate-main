{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.4.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "HMM Regime Classifier dashboard — Push 45-46",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {"options": {"-1": {"color": "red",   "index": 0, "text": "bear"},
                         "0":  {"color": "yellow", "index": 1, "text": "sideways"},
                         "1":  {"color": "green",  "index": 2, "text": "bull"}},
             "type": "value"}
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "yellow", "value": 0},
              {"color": "green",  "value": 1}
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "HMM Regime",
      "type": "stat",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"},
         "expr": "argus_regime_label",
         "legendFormat": "regime",
         "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "percentunit"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "bull"},     "properties": [{"id": "color", "value": {"fixedColor": "green",  "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "sideways"}, "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "bear"},     "properties": [{"id": "color", "value": {"fixedColor": "red",    "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 4, "y": 0},
      "id": 2,
      "options": {"fillOpacity": 60, "gradientMode": "none", "stacking": {"group": "A", "mode": "normal"}},
      "title": "Regime State Probabilities",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"},
         "expr": "argus_regime_bull_prob",     "legendFormat": "bull",     "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"},
         "expr": "argus_regime_sideways_prob", "legendFormat": "sideways", "refId": "B"},
        {"datasource": {"type": "prometheus", "uid": "${datasource}"},
         "expr": "argus_regime_bear_prob",     "legendFormat": "bear",     "refId": "C"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "yellow", "value": 0.9},
              {"color": "green",  "value": 1.1}
            ]
          },
          "unit": "none", "decimals": 2,
          "min": 0.4, "max": 1.5
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 4},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Regime Scalar",
      "type": "stat",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"},
         "expr": "argus_regime_scalar",
         "legendFormat": "scalar",
         "refId": "A"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "none"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 4,
      "options": {},
      "title": "Regime Scalar History",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "${datasource}"},
         "expr": "argus_regime_scalar",
         "legendFormat": "scalar",
         "refId": "A"}
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["argus", "regime", "hmm"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Argus — HMM Regime",
  "uid": "argus-regime",
  "version": 1
}
