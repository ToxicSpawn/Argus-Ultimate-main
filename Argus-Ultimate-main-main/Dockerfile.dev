# Argus Ultimate — Development image with hot-reload
# Push 64: Container-Deploy
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ git curl make \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
COPY version.py ./

RUN pip install --upgrade pip \
    && pip install -e ".[ai,dev]" --no-warn-script-location 2>/dev/null || \
       pip install -e ".[dev]" --no-warn-script-location

# Source mounted at runtime via volume
COPY . .

EXPOSE 8080

# Dev: hot-reload via uvicorn
CMD ["argus", "start", "--config", "core/config/argus_default.yaml"]
