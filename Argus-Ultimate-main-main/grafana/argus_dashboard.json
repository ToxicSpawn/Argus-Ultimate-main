{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Argus Ultimate — Algorithmic Trading Bot Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Portfolio",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red",   "value": 0}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 1},
      "id": 1,
      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "argus_equity_usd",
          "legendFormat": "Equity",
          "refId": "A"
        },
        {
          "expr": "argus_cash_usd",
          "legendFormat": "Cash",
          "refId": "B"
        }
      ],
      "title": "Equity Curve",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 2},
              {"color": "orange", "value": 3.5},
              {"color": "red",    "value": 5}
            ]
          },
          "min": 0, "max": 10
        }
      },
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "argus_drawdown_pct",
          "legendFormat": "Drawdown %",
          "refId": "A"
        }
      ],
      "title": "Current Drawdown",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",   "value": null},
              {"color": "green", "value": 0}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 9},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [
        {
          "expr": "argus_realised_pnl_usd",
          "legendFormat": "Realised PnL",
          "refId": "A"
        }
      ],
      "title": "Realised PnL",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",   "value": null},
              {"color": "green", "value": 0}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 9},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "argus_unrealised_pnl_usd",
          "legendFormat": "Unrealised PnL",
          "refId": "A"
        }
      ],
      "title": "Unrealised PnL",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",   "value": null},
              {"color": "yellow","value": 0.4},
              {"color": "green", "value": 0.55}
            ]
          },
          "min": 0, "max": 1
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 9},
      "id": 5,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "argus_win_rate",
          "legendFormat": "Win Rate",
          "refId": "A"
        }
      ],
      "title": "Win Rate",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "blue", "value": null}
          ]}
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 9},
      "id": 6,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "targets": [
        {
          "expr": "argus_open_positions",
          "legendFormat": "Open Positions",
          "refId": "A"
        }
      ],
      "title": "Open Positions",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 101,
      "title": "Trading Activity",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 1, "fillOpacity": 5}}
      },
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 14},
      "id": 7,
      "targets": [
        {
          "expr": "rate(argus_orders_total[5m])",
          "legendFormat": "Orders/s",
          "refId": "A"
        },
        {
          "expr": "rate(argus_fills_total[5m])",
          "legendFormat": "Fills/s",
          "refId": "B"
        },
        {
          "expr": "rate(argus_orders_rejected_total[5m])",
          "legendFormat": "Rejections/s",
          "refId": "C"
        }
      ],
      "title": "Order / Fill Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "custom": {"lineWidth": 2}}
      },
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 14},
      "id": 8,
      "targets": [
        {
          "expr": "argus_daily_pnl_usd",
          "legendFormat": "Daily PnL",
          "refId": "A"
        },
        {
          "expr": "argus_hourly_pnl_usd",
          "legendFormat": "Hourly PnL",
          "refId": "B"
        }
      ],
      "title": "PnL — Daily & Hourly",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 21},
      "id": 102,
      "title": "Infrastructure",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "custom": {"lineWidth": 1}}
      },
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 22},
      "id": 9,
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=\"argus\"}[5m])",
          "legendFormat": "Argus CPU",
          "refId": "A"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=\"redis\"}[5m])",
          "legendFormat": "Redis CPU",
          "refId": "B"
        }
      ],
      "title": "Container CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"unit": "bytes", "custom": {"lineWidth": 1}}
      },
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 22},
      "id": 10,
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=\"argus\"}",
          "legendFormat": "Argus Memory",
          "refId": "A"
        },
        {
          "expr": "container_memory_usage_bytes{name=\"postgres\"}",
          "legendFormat": "Postgres Memory",
          "refId": "B"
        }
      ],
      "title": "Container Memory Usage",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["argus", "trading", "crypto"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
