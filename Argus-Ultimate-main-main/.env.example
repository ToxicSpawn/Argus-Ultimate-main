# =============================================================================
# ARGUS-ULTIMATE — UNIFIED ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file. It is already in .gitignore.
#
# Sections:
#   1. Exchange API Keys
#   2. Trading Mode & Pairs
#   3. Risk Management
#   4. External Data APIs
#   5. Notifications
#   6. Infrastructure / Server
#   7. ML / RL / Quantum
#   8. Logging & Monitoring
# =============================================================================


# -----------------------------------------------------------------------------
# 1. EXCHANGE API KEYS
# -----------------------------------------------------------------------------
# Kraken (primary exchange — Australia)
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here
KRAKEN_SANDBOX=true                          # Set to false for live trading

# Coinbase Advanced Trade (secondary — Australia)
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here
COINBASE_SANDBOX=true

# Binance (optional)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Bybit (optional)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true


# -----------------------------------------------------------------------------
# 2. TRADING MODE & PAIRS
# -----------------------------------------------------------------------------
# Mode: paper | live | hybrid
TRADING_MODE=paper

# Primary exchange to trade on
PRIMARY_EXCHANGE=kraken

# Static trading pairs (comma-separated Kraken format)
# Leave empty to use dynamic pair selection (--dynamic flag)
TRADING_PAIRS=XBT/AUD,ETH/AUD,SOL/AUD

# Base currency for account balance
BASE_CURRENCY=AUD

# Initial paper trading capital (AUD)
PAPER_INITIAL_BALANCE=10000.0

# Dynamic pair selection
DYNAMIC_PAIRS=false
DYNAMIC_PAIR_COUNT=3


# -----------------------------------------------------------------------------
# 3. RISK MANAGEMENT
# -----------------------------------------------------------------------------
# Maximum position size as fraction of portfolio (0.0 – 1.0)
MAX_POSITION_SIZE=0.10

# Maximum drawdown before circuit breaker triggers (fraction)
MAX_DRAWDOWN=0.15

# Stop loss percentage per trade
STOP_LOSS_PCT=0.02

# Take profit percentage per trade
TAKE_PROFIT_PCT=0.04

# Maximum concurrent open positions
MAX_OPEN_POSITIONS=5

# Daily loss limit (AUD). Bot pauses if hit.
DAILY_LOSS_LIMIT=500.0

# Leverage (1 = no leverage)
DEFAULT_LEVERAGE=1


# -----------------------------------------------------------------------------
# 4. EXTERNAL DATA APIs
# -----------------------------------------------------------------------------
# CoinGlass — funding rates, open interest, liquidations
COINGLASS_API_KEY=

# Alternative.me — Fear & Greed Index (free, no key needed)
# FEAR_GREED_ENABLED=true

# Whale Alert — large transaction monitoring
WHALE_ALERT_API_KEY=

# CryptoCompare — historical OHLCV
CRYPTOCOMPARE_API_KEY=

# NewsAPI — crypto news sentiment
NEWS_API_KEY=

# Glassnode — on-chain analytics (optional)
GLASS_NODE_API_KEY=

# External data polling interval in seconds (min 5 recommended)
EXTERNAL_DATA_INTERVAL=5


# -----------------------------------------------------------------------------
# 5. NOTIFICATIONS
# -----------------------------------------------------------------------------
# Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# Alert thresholds
TELEGRAM_ALERT_ON_TRADE=true
TELEGRAM_ALERT_ON_DRAWDOWN=true
TELEGRAM_DAILY_SUMMARY=true


# -----------------------------------------------------------------------------
# 6. INFRASTRUCTURE / SERVER
# -----------------------------------------------------------------------------
# Server profile: local | hetzner | vultr | r740
SERVER_PROFILE=local

# Redis (used for caching and pub/sub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka (used for alternative data streaming)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=false

# Prometheus metrics port
PROMETHEUS_PORT=8000

# Dashboard / API port
DASHBOARD_PORT=8080

# Timezone (for scheduling and logging)
TZ=Australia/Sydney


# -----------------------------------------------------------------------------
# 7. ML / RL / QUANTUM
# -----------------------------------------------------------------------------
# RL training device: cpu | cuda | mps
RL_DEVICE=cpu

# Enable GPU acceleration (requires CUDA)
GPU_ENABLED=false

# Reinforcement learning algorithm: PPO | SAC | DQN
RL_ALGORITHM=PPO

# Model checkpoint directory
CHECKPOINT_DIR=./checkpoints

# Quantum simulation mode: numpy | torch | qiskit
QUANTUM_BACKEND=numpy

# Enable quantum circuit simulation
QUANTUM_ENABLED=true

# Number of parallel RL environments
RL_NUM_ENVS=4

# Steps between policy updates
RL_UPDATE_INTERVAL=2048


# -----------------------------------------------------------------------------
# 8. LOGGING & MONITORING
# -----------------------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log directory
LOG_DIR=./logs

# Enable structured JSON logging
LOG_JSON=false

# Grafana / Prometheus scrape enabled
METRICS_ENABLED=true

# Retain logs for N days
LOG_RETENTION_DAYS=30
